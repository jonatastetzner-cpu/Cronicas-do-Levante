function buildDeepPath(base,cfg){
  cfg.chapters.forEach((ch,ci)=>{
    PHASES.forEach((phase,pi)=>{
      const id=base+(ci*PHASES.length)+pi;
      const last=ci===cfg.chapters.length-1&&pi===PHASES.length-1;
      const next=last?cfg.ending:id+1;
      const s=phase(ch);
      const opts=phaseOptions(ch,pi,ci,cfg.name);
      const actionStats=['escuta','servico','prudencia','ousadia'];
      const actions=opts.map((t,ai)=>({t:contextAction(t),p:next,mark:s.mark,rel:s.rel,desc:s.desc,stat:actionStats[ai]}));
      makeScene(id,cfg.name,s.title,s.body,actions,{path:cfg.name});
    });
  });
}
Object.entries(DEEP_PATHS).forEach(([base,cfg])=>buildDeepPath(Number(base),cfg));

