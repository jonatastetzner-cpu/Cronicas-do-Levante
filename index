<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Crônicas do Levante</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,400&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
:root{--parch:#f5edd6;--parch2:#ede0bc;--ink:#2c1a0e;--ink2:#4a2f1a;--gold:#8b6914;--gold2:#c49a2a;--blood:#7b1e1e;--stone:#3d3028;--stone2:#5a4535;--sep:1px solid rgba(139,105,20,.25);--r:7px}
html,body{min-height:100%;background:#0e0a04;color:var(--ink);font-family:'Crimson Pro',serif}
body{padding:16px;display:flex;justify-content:center}
.shell{width:100%;max-width:1040px;min-height:94vh;background:var(--parch);border:2px solid var(--gold);border-radius:10px;overflow:hidden;box-shadow:0 0 70px rgba(0,0,0,.7);position:relative}
.hdr{background:var(--stone);border-bottom:2px solid var(--gold);padding:13px 20px;display:flex;gap:12px;justify-content:space-between;align-items:center}
.hdr-title{font-family:Cinzel,serif;color:var(--gold2);letter-spacing:3px;font-size:15px;font-weight:700}
.hdr-sub{font-family:Cinzel,serif;color:rgba(232,192,96,.75);font-size:10px;letter-spacing:1px;text-align:right;display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end}
.hdr-sub span{border:1px solid rgba(196,154,42,.35);border-radius:4px;padding:5px 10px;background:rgba(196,154,42,.07)}
.hdr-sub .hidden{display:none}
.tabs{display:flex;background:var(--stone2);border-bottom:2px solid var(--gold);overflow-x:auto}
.tab{font-family:Cinzel,serif;font-size:10px;letter-spacing:1px;color:rgba(232,192,96,.62);padding:9px 14px;border-right:var(--sep);white-space:nowrap;cursor:pointer}
.tab.active{background:var(--parch);color:var(--ink);font-weight:600;margin-bottom:-2px;border-bottom:2px solid var(--parch)}
.content{display:none;padding:16px}
.content.active{display:block}
.game{display:grid;grid-template-columns:1fr 270px;gap:15px}
.main{min-width:0}
.log{background:rgba(0,0,0,.06);border:1px solid rgba(139,105,20,.18);border-radius:var(--r);padding:9px 12px;margin-bottom:12px;max-height:96px;overflow:auto}
.log div{font-size:12px;color:var(--ink2);line-height:1.5}
.scene{background:rgba(255,255,255,.35);border:1px solid rgba(139,105,20,.22);border-radius:var(--r);padding:18px;animation:fade .25s ease}
.loc{font-family:Cinzel,serif;font-size:9px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:7px}
.title{font-family:Cinzel,serif;font-size:20px;font-weight:600;line-height:1.25;margin-bottom:12px}
.body{font-size:17px;line-height:1.75;color:var(--ink2)}
.body em{color:var(--ink);font-style:italic}
.quote{display:block;border-left:3px solid var(--gold);padding:8px 13px;margin:12px 0;background:rgba(139,105,20,.06);font-style:italic}
.act-head{display:flex;align-items:center;gap:10px;margin:14px 0 8px}
.act-label{font-family:Cinzel,serif;font-size:10px;letter-spacing:1.5px;color:var(--gold);flex:1;border-bottom:var(--sep);padding-bottom:5px}
.back{border:1px solid rgba(139,105,20,.3);background:transparent;color:var(--ink2);font-family:Cinzel,serif;font-size:10px;border-radius:4px;padding:5px 10px;cursor:pointer}
.back:disabled{opacity:.35;cursor:not-allowed}
.acts{display:flex;flex-direction:column;gap:8px}
.act{background:var(--stone);color:var(--parch2);border:1px solid var(--stone2);border-radius:5px;padding:12px 14px;font-family:'Crimson Pro',serif;font-size:16px;line-height:1.35;text-align:left;cursor:pointer;transition:.15s}
.act:hover{background:var(--blood);border-color:var(--gold)}
.act small{font-family:Cinzel,serif;color:rgba(232,192,96,.7);margin-right:8px}
.side{background:rgba(139,105,20,.04);border:1px solid rgba(139,105,20,.17);border-radius:var(--r);padding:13px;align-self:start}
.side h3{font-family:Cinzel,serif;font-size:10px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin:12px 0 7px}
.side h3:first-child{margin-top:0}
.item{font-size:13.5px;line-height:1.55;color:var(--ink2);border-bottom:1px solid rgba(139,105,20,.08);padding:5px 0}
.dim{opacity:.55;font-style:italic}
.ending{border:2px solid var(--gold);background:rgba(139,105,20,.08);border-radius:var(--r);padding:24px}
.ending-badge{text-align:center;font-family:Cinzel,serif;font-size:10px;letter-spacing:3px;color:var(--gold2);margin-bottom:10px}
.ending-title{text-align:center;font-family:Cinzel,serif;font-size:24px;margin-bottom:14px}
.ending-body{font-size:17px;line-height:1.85;color:var(--ink2)}
.restart{display:block;margin:18px auto 0;background:var(--stone);color:var(--gold2);border:1px solid var(--gold);border-radius:5px;padding:10px 24px;font-family:Cinzel,serif;cursor:pointer}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px}
.card{background:rgba(255,255,255,.35);border:1px solid rgba(139,105,20,.2);border-radius:var(--r);padding:14px}
.card h2{font-family:Cinzel,serif;font-size:15px;margin-bottom:8px}
.card p,.card li{font-size:15px;line-height:1.55;color:var(--ink2)}
.card ul{padding-left:18px}
@keyframes fade{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:760px){body{padding:8px}.game{grid-template-columns:1fr}.side{order:2}.hdr{flex-direction:column;align-items:flex-start}.hdr-sub{text-align:left}.body{font-size:16px}.title{font-size:18px}}
</style>
</head>
<body>
<div class="shell">
  <div class="hdr"><div class="hdr-title">CRÔNICAS DO LEVANTE</div><div class="hdr-sub"><span id="pill-ano">Ano: ???</span><span id="pill-local" class="hidden"></span><span id="pill-rei" class="hidden"></span></div></div>
  <div class="tabs"><div class="tab active" onclick="tab('jogo')">Jogo</div><div class="tab" onclick="tab('linha')">Descobertas</div><div class="tab" onclick="tab('ajuda')">Como jogar</div></div>
  <div id="jogo" class="content active"><div class="game"><div class="main"><div class="log" id="log"><div>Você acordou longe do seu mundo.</div></div><div class="scene" id="scene"></div><div class="act-head"><div class="act-label">O que você faz?</div><button class="back" id="back" onclick="voltar()" disabled>Voltar</button></div><div class="acts" id="acts"></div></div><aside class="side"><h3>Você</h3><div class="item" id="nome">estrangeiro</div><h3>Descobertas</h3><div id="desc"><div class="item dim">Nada claro ainda.</div></div><h3>Relações</h3><div id="rel"><div class="item dim">Ninguém confia em você ainda.</div></div><h3>Marcas</h3><div id="marks"><div class="item dim">Nenhuma decisão profunda ainda.</div></div><h3>Caminho</h3><div id="cam"><div class="item dim">Indefinido</div></div></aside></div></div>
  <div id="linha" class="content"><div class="grid" id="linha-grid"></div></div>
  <div id="ajuda" class="content"><div class="grid"><div class="card"><h2>Ideia central</h2><p>Você não recebe a história pronta. Primeiro sobrevive, escuta nomes e descobre aos poucos em que parte da Bíblia caiu.</p></div><div class="card"><h2>Como avançar</h2><p>Escolha pela intenção do personagem, não tentando adivinhar final certo. Algumas decisões aproximam você de pessoas, lugares e responsabilidades diferentes.</p></div><div class="card"><h2>Descobertas</h2><p>O painel guarda nomes, relações e marcas importantes. Ele mostra o que você aprendeu durante a jornada, sem entregar o que ainda não viveu.</p></div><div class="card"><h2>Duração</h2><p>Cada jornada é longa o bastante para explorar conversas, consequências e detalhes históricos antes de chegar a um final.</p></div></div></div>
</div>
<script>
const CENAS={};
const G={cena:0,hist:[],flags:{},desc:[],rel:[],marks:[],path:null,stats:{}};

function uniquePush(list,x){if(x&&!list.includes(x))list.push(x)}
function esc(s){return String(s).replace(/[&<>]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[m]))}
function makeScene(id,loc,title,body,acao,opt={}){CENAS[id]={loc,title,body,acao,...opt}}
function makeEnding(id,title,body,opt={}){CENAS[id]={ending:true,etitle:title,ebody:body,...opt}}
function snapshot(){return JSON.parse(JSON.stringify({cena:G.cena,flags:G.flags,desc:G.desc,rel:G.rel,marks:G.marks,path:G.path,stats:G.stats}))}
function restore(s){Object.assign(G,{cena:s.cena,flags:s.flags,desc:s.desc,rel:s.rel,marks:s.marks,path:s.path,stats:s.stats||{}})}
function meta(m={}){
  uniquePush(G.desc,m.desc); uniquePush(G.rel,m.rel); uniquePush(G.marks,m.mark);
  if(m.path)G.path=m.path; if(m.reveal)Object.assign(G.flags,m.reveal);
  if(m.stat)G.stats[m.stat]=(G.stats[m.stat]||0)+1;
}

makeScene(0,'','O despertar',`Pedras quentes. Sol forte. Você abre os olhos num beco estreito, entre muros claros. Há poeira na boca, cheiro de pão no ar e vozes numa língua que parece antiga demais para ainda estar viva.<br><br>Você procura o celular. A tela está morta. Nada vibra. Nada responde. O mundo respondeu por você: você não está onde deveria estar.`,[
{t:'Ficar quieto e observar antes de sair',p:1,mark:'Você escolheu observar antes de se revelar.'},
{t:'Verificar o que ainda carrega consigo',p:2,mark:'Você percebeu que seus objetos modernos podem denunciar você.'},
{t:'Levantar e procurar água',p:3,mark:'A sede falou mais alto que o medo.'}
]);
makeScene(1,'Beco de pedra','Antes de se mostrar',`Você espera. Passam sandálias, túnicas, cestos de figos, crianças carregando jarros. Ninguém usa metal polido como o seu. Ninguém fala como você.<br><br>Do outro lado da rua, um homem observa suas roupas por tempo demais. Você entende que sobreviver aqui começa por parecer menos impossível.`,[
{t:'Sair devagar, sem chamar atenção',p:3},
{t:'Esconder o celular e cobrir as roupas',p:2,desc:'Suas roupas e objetos não pertencem a esta época.'}
],{desc:'As ruas não pertencem ao seu tempo.'});
makeScene(2,'Beco de pedra','O que restou',`No bolso há vidro, metal e silêncio. O aparelho não acende. Sua carteira, suas chaves e seus documentos parecem relíquias de um reino que ninguém aqui saberia nomear.<br><br>Você guarda tudo sob a roupa. Pela primeira vez, sente medo de que uma prova da sua vida vire acusação contra você.`,[
{t:'Sair para procurar água',p:3},
{t:'Tentar trocar um objeto por ajuda',p:4,mark:'Você quase usou o futuro como moeda.'}
],{desc:'Seu objeto moderno não funciona aqui.'});
makeScene(3,'Rua movimentada','A cidade viva',`Você chega a uma rua cheia de barracas. Pão achatado, tâmaras, couro, azeite, cerâmica. Ao fundo, numa parte mais alta, há uma tenda cercada por homens de linho. Não parece uma casa. Parece um limite.<br><br>Perto do poço, uma mulher nota sua sede e aponta para a fila.`,[
{t:'Ir ao poço e pedir água por gestos',p:4},
{t:'Aproximar-se do homem que está te observando',p:5},
{t:'Subir até a tenda cercada por homens de linho',p:6}
],{desc:'Uma tenda sagrada domina a parte alta da cidade.'});
makeScene(4,'Praça do poço','Água emprestada',`A mulher entende sua garganta seca antes de entender suas palavras. Ela entrega uma cuia. A água é morna, mas parece trazer você de volta ao corpo.<br><br>Ela diz devagar: <em>maim</em>. Depois aponta para si: <em>Hana</em>. Você repete mal. Ela ri sem crueldade.`,[
{t:'Apontar ao redor e tentar perguntar onde está',p:7,rel:'Hana viu você como estrangeiro, não como ameaça.'},
{t:'Ficar perto do poço para aprender palavras',p:8,desc:'Maim quer dizer água.'}
],{desc:'Maim quer dizer água.'});
makeScene(5,'Mercado','Ben-Hur',`O homem do mercado se aproxima com cuidado. Ele te oferece bebida de tâmaras e aponta para si: <em>Ben-Hur</em>. Depois aponta para você, esperando um nome.<br><br>Seu nome verdadeiro soa duro demais naquela língua. Ben-Hur tenta repetir, desiste e sorri.`,[
{t:'Aceitar um nome mais simples para sobreviver',p:8,desc:'Você passa a ser chamado de Yonah.',rel:'Ben-Hur decidiu ajudar você.'},
{t:'Perguntar com gestos o nome da cidade',p:7,rel:'Ben-Hur percebeu que você está perdido.'}
]);
makeScene(6,'Colina da tenda','Mishkan',`De perto, a tenda é mais solene que bonita. Tecido, incenso, silêncio e limite. Um guarda ergue a mão antes que você avance.<br><br>Um homem de linho diz duas palavras com reverência: <em>Mishkan</em>. <em>Aron</em>. Você não entende tudo, mas sente que ali a cidade respira diante de Deus.`,[
{t:'Recuar antes de causar problema',p:8,desc:'A tenda na colina é sagrada.'},
{t:'Perguntar quem governa a cidade',p:7,desc:'Você ouviu falar do Mishkan e da arca.'}
],{desc:'A tenda na colina é sagrada.'});
makeScene(7,'Jerusalém','O nome que atravessa',`Depois de gestos, erros e risadas contidas, alguém finalmente entende sua pergunta. A resposta vem clara:<br><br><span class="quote">Yerushalaim.</span>Jerusalém.<br><br>O nome atravessa você como um choque. Não é museu. Não é peça. É rua, poeira, fome, gente real.`,[
{t:'Perguntar quem é o rei',p:9},
{t:'Voltar ao poço antes que anoiteça',p:8}
],{desc:'Você está em Jerusalém.',reveal:{local:'Jerusalém'}});
makeScene(8,'Jerusalém','Primeiros dias',`Você sobrevive carregando sacos, varrendo pátios, repetindo palavras. Ben-Hur arruma um canto para você dormir. Hana te ensina a não encarar gente poderosa por tempo demais.<br><br>Um velho escriba chamado Eli-Shama nota que você aprende rápido. Ele não pergunta de onde você veio. Pergunta o que você teme descobrir.`,[
{t:'Aproximar-se de Eli-Shama',p:10,rel:'Eli-Shama começou a observar você com interesse.'},
{t:'Perguntar discretamente sobre o rei',p:9}
],{rel:'Hana e Ben-Hur ajudam você a sobreviver.'});
makeScene(9,'Jerusalém','O rei',`Quando você pergunta quem governa, a resposta vem com orgulho: <em>Davi ben Jessé, rei de Israel</em>.<br><br>As peças começam a se aproximar. Davi. Jerusalém. A tenda. A arca. Você ainda não sabe em que capítulo caiu, mas já sente que qualquer passo pode tocar algo maior que você.`,[
{t:'Guardar a informação e continuar ouvindo',p:10},
{t:'Tentar saber mais sobre a casa do rei',p:11}
],{desc:'Davi reina em Jerusalém.',reveal:{rei:'Rei Davi',ano:'Dias de Davi'}});
makeScene(10,'Casa de Eli-Shama','O escriba velho',`Eli-Shama deixa você copiar sinais em um caco de cerâmica. Depois diz, sem olhar para você:<br><br><span class="quote">Estrangeiro que escuta demais sempre acaba diante de uma escolha.</span>Ele fala da casa do rei com cuidado. Nomes aparecem como brasas cobertas: Amnom. Tamar. Absalão.`,[
{t:'Pedir que ele explique os nomes',p:11,rel:'Eli-Shama sabe que você entende mais do que aparenta.'},
{t:'Fingir que os nomes não mexeram com você',p:12}
],{desc:'Nomes da casa de Davi começaram a aparecer: Amnom, Tamar e Absalão.'});
makeScene(11,'Portões do palácio','Rumores cortados',`Perto do palácio, as frases morrem quando você chega. Um servo comenta que Amnom está recolhido, sem comer. Outro fala de Tamar com respeito e medo. Quando Absalão passa, o povo abre caminho para sua beleza e sua posição.<br><br>Você percebe que a história que conhece não está num livro. Ela ainda está respirando.`,[
{t:'Ficar em Jerusalém e tentar agir com prudência',p:100,path:'Jerusalém - O aviso'},
{t:'Ficar em Jerusalém como testemunha',p:200,path:'Jerusalém - A testemunha'},
{t:'Agir rápido antes que seja tarde',p:300,path:'Jerusalém - Zelo sem sabedoria'},
{t:'Procurar uma caravana para terras distantes',p:12}
],{desc:'A crise da casa de Davi ainda está se formando.',reveal:{linha:'Tamar, Amnom, Absalão e Davi'}});
makeScene(12,'Portão das caravanas','Quatro estradas',`Você poderia ficar. Também poderia partir antes que a casa de Davi engula sua vida. No portão das caravanas, quatro grupos se preparam: homens que falam de especiarias do oriente, viajantes de Cuxe, escribas rumo aos rios antigos e mercadores de Tiro.<br><br>Jerusalém ficará. A história principal seguirá. Mas talvez Deus também tenha perguntas nas bordas do mapa.`,[
{t:'Seguir rumo à Índia pelas rotas de especiarias',p:400,path:'Índia - A semente distante'},
{t:'Descer rumo a Cuxe com viajantes do sul',p:500,path:'Cuxe - O servo que busca'},
{t:'Ir para a Mesopotâmia, terra de rios e escribas',p:600,path:'Babilônia - À sombra do exílio'},
{t:'Subir para Tiro, entre cedros e navios',p:700,path:'Tiro - Cedros e aliança'}
],{desc:'Há rotas antigas ligando Jerusalém a povos distantes.'});

makeScene(100,'Palácio de Davi','O aviso discreto',`Você escolhe ficar perto do perigo sem transformá-lo em espetáculo. Lava jarros, carrega água e escuta servas que não podem falar alto.<br><br>O nome de Tamar aparece sempre acompanhado de um cuidado estranho. O nome de Amnom aparece como doença.`,[
{t:'Levar o que ouviu a Eli-Shama',p:101,mark:'Você procurou conselho antes de acusar.'},
{t:'Tentar confirmar o rumor com uma serva de Tamar',p:102,mark:'Você buscou proteger sem expor Tamar.'}
],{path:'Jerusalém - O aviso'});
makeScene(101,'Casa de Eli-Shama','Conselho antes da pressa',`Eli-Shama escuta sem interromper. Quando você termina, ele fecha os olhos.<br><br><span class="quote">Na casa de reis, pecado escondido vira guerra. Mas uma palavra lançada sem testemunha também vira faca.</span>Ele promete procurar alguém que Davi ainda respeite.`,[
{t:'Pedir que ele procure o profeta Natan',p:103,rel:'Eli-Shama aceitou carregar parte do risco.'},
{t:'Voltar ao palácio e observar a porta de Amnom',p:103}
]);
makeScene(102,'Pátio das servas','A serva de Tamar',`Uma serva entende sua pergunta antes que você termine. O rosto dela muda. Ela não acusa ninguém, mas pergunta:<br><br><span class="quote">Se você sabe, por que pergunta como homem curioso?</span>Você responde baixo: porque quer que Tamar não fique sozinha.`,[
{t:'Prometer que não vai espalhar o nome de Tamar',p:103,rel:'Uma serva de Tamar decidiu confiar um pouco em você.'},
{t:'Pedir que ela avise Tamar sem alarme',p:103,mark:'Você tentou proteger a honra de Tamar junto com sua segurança.'}
]);
makeScene(103,'Corredores do palácio','A porta preparada',`A notícia se encaixa tarde demais: Amnom pode pedir que Tamar leve comida ao quarto dele. O pretexto parece cuidado de família. O perigo parece porta fechada.<br><br>Você não tem força para mandar em ninguém. Tem apenas nomes, medo e alguns ouvidos certos.`,[
{t:'Procurar Natan imediatamente',p:104},
{t:'Falar com Tamar por meio da serva',p:105}
],{desc:'O perigo contra Tamar está ligado ao quarto de Amnom.'});
makeScene(104,'Casa de Natan','O profeta escuta',`Natan ouve como quem pesa cada palavra diante de Deus. Ele não te chama de louco. Só pergunta quem mais sabe.<br><br>Quando você cita Eli-Shama e a serva, Natan se levanta. O rosto dele não tem pressa. Tem gravidade.`,[
{t:'Ir com Natan até Davi',p:106,rel:'Natan levou seu aviso a sério.'},
{t:'Esperar enquanto Natan confirma os fatos',p:106}
]);
makeScene(105,'Pátio interno','Tamar ouve',`Tamar não recebe sua fala como fofoca. Recebe como peso. Ela baixa os olhos por um instante, depois pergunta se Absalão sabe.<br><br>Você percebe que proteger alguém também é não roubar dela a própria voz.`,[
{t:'Dizer que Natan precisa saber',p:104,rel:'Tamar foi tratada como pessoa, não como rumor.'},
{t:'Pedir que ela não vá sozinha a lugar nenhum',p:106}
]);
makeScene(106,'Casa do rei','Davi informado',`Davi envelhece diante de você enquanto escuta. O rei que venceu gigantes agora precisa olhar para a própria casa.<br><br>Natan não grita. Tamar não é exposta. Eli-Shama fica em silêncio. O pecado ainda é possível, mas a porta que ele queria usar já não está invisível.`,[
{t:'Pedir proteção imediata para Tamar',p:107},
{t:'Esperar a decisão do rei',p:107}
],{rel:'Davi ouviu o aviso antes do crime.'});
makeScene(107,'Palácio de Davi','A linha deslocada',`Uma ordem pequena muda a rotina: Tamar não vai sozinha. Amnom percebe que alguém viu a sombra antes do ato. Absalão nota que algo foi impedido sem saber exatamente o quê.<br><br>Naquela noite, Jerusalém parece respirar. Mas você sente um frio novo: se a ferida que moveria tantos acontecimentos não aconteceu, o que mais você deslocou?`,[
{t:'Permanecer para ver o novo futuro',p:190},
{t:'Perguntar a Natan se salvar um inocente pode quebrar uma promessa',p:190}
]);

makeScene(200,'Jerusalém','Perto, mas parado',`Você fica. Trabalha. Escuta. Decide que talvez não caiba a você tocar a casa do rei.<br><br>Rumores passam por você como água por pedra: Amnom doente, Tamar chamada, servos inquietos. Você entende o suficiente para temer e não o suficiente para agir sem se odiar.`,[
{t:'Continuar observando',p:201,mark:'Você escolheu não interferir nos primeiros sinais.'},
{t:'Procurar Eli-Shama, mas sem pedir ação',p:201,rel:'Eli-Shama percebeu seu medo de agir.'}
],{path:'Jerusalém - A testemunha'});
makeScene(201,'Poço de Hana','O silêncio depois',`A cidade amanhece diferente. Mulheres falam baixo. Homens mudam de assunto. O nome de Tamar some da boca pública como se calar apagasse violência.<br><br>Hana chora sem explicar. Você não precisa que ela explique tudo.`,[
{t:'Perguntar por Tamar com cuidado',p:202},
{t:'Guardar silêncio por vergonha',p:202,mark:'Você carregou culpa por ter entendido tarde demais.'}
],{desc:'Tamar foi ferida dentro da casa real.'});
makeScene(202,'Portão do palácio','Absalão calado',`Absalão passa pelo portão sem sorrir. Sua beleza ainda chama atenção, mas algo nele ficou duro como pedra aquecida.<br><br>Você ouve que ele levou Tamar para sua casa. Ele não fala com Amnom. Não grita com Davi. O silêncio dele parece uma espada guardada.`,[
{t:'Observar Absalão no portão',p:203,desc:'Absalão recolheu Tamar e guardou silêncio.'},
{t:'Ficar com Eli-Shama e registrar nomes',p:203}
]);
makeScene(203,'Jerusalém','Dois anos',`O tempo não cura. Apenas ensina a cidade a pisar em volta da ferida. Davi lamenta, mas não corrige. Amnom vive. Tamar permanece como uma dor que ninguém quer nomear.<br><br>Dois anos depois, Absalão prepara um banquete. Alguns chamam de reconciliação. Eli-Shama chama de colheita.`,[
{t:'Prestar atenção aos preparativos',p:204},
{t:'Tentar avisar alguém, mesmo tarde',p:204,mark:'Você tentou acordar quando a vingança já estava madura.'}
]);
makeScene(204,'Banquete dos filhos do rei','Sangue entre irmãos',`A notícia chega antes dos cavalos: Amnom morreu. Absalão fugiu.<br><br>Por um instante, todos os rumores voltam com corpo. O que foi escondido no quarto de um príncipe agora saiu pelos caminhos em forma de sangue.`,[
{t:'Ir ao portão ouvir notícias',p:205},
{t:'Ficar com Eli-Shama e escrever',p:205,rel:'Eli-Shama confiou a você parte do registro.'}
],{desc:'Absalão matou Amnom e fugiu.'});
makeScene(205,'Jerusalém','Exílio e retorno',`Gesur vira nome repetido em sussurros. Davi lamenta Amnom e sente falta de Absalão. Anos se dobram. Absalão volta, mas a casa não se reconcilia de verdade.<br><br>Você entende que pecado não tratado não desaparece. Ele muda de roupa.`,[
{t:'Observar Absalão ganhar o coração do povo',p:206},
{t:'Acompanhar Davi à distância',p:206}
],{desc:'Absalão voltou a Jerusalém, mas a ruptura permaneceu.'});
makeScene(206,'Estrada para fora da cidade','O filho contra o pai',`Absalão rouba o coração do povo. A cidade divide o olhar. Davi sai de Jerusalém chorando, e você vê o rei atravessar a mesma poeira em que acordou.<br><br>Depois vem a guerra. Depois a árvore. Depois a notícia que fere Davi mais que vitória.`,[
{t:'Ouvir o lamento de Davi',p:290},
{t:'Registrar a história até o fim',p:290}
],{desc:'Absalão se rebelou contra Davi e morreu.'});

makeScene(300,'Jerusalém','Pressa',`Você decide que esperar é covardia. Ainda não tem testemunhas, mas tem medo suficiente para agir.<br><br>Seu aviso sai alto demais no lugar errado. Servos repetem pedaços. O nome de Tamar começa a circular antes que Tamar esteja protegida.`,[
{t:'Confrontar um servo de Amnom',p:301,mark:'Sua pressa transformou cuidado em alarme público.'},
{t:'Procurar Absalão imediatamente',p:302,mark:'Você levou meia verdade ao coração mais inflamável.'}
],{path:'Jerusalém - Zelo sem sabedoria'});
makeScene(301,'Corredor do palácio','Amnom alertado',`Amnom percebe que alguém está olhando para ele. O perigo não desaparece. Apenas aprende a se esconder melhor.<br><br>Servos somem. Portas se fecham. O palácio inteiro começa a proteger sua própria aparência.`,[
{t:'Tentar corrigir o que falou',p:303},
{t:'Buscar Davi antes que piore',p:304}
]);
makeScene(302,'Casa de Absalão','Metade da verdade',`Absalão escuta pouco e completa o resto com ira. Seus olhos deixam de pedir verdade e passam a procurar alvo.<br><br>Quando você tenta recuar, já é tarde: sua intenção virou combustível.`,[
{t:'Tentar acalmar Absalão',p:303},
{t:'Dizer que ainda não há certeza',p:303}
],{rel:'Absalão ouviu você, mas não como você esperava.'});
makeScene(303,'Pátio interno','Tamar exposta',`Tamar é cercada por cuidados e olhares. Alguns dizem que querem protegê-la. Outros querem saber detalhes. Quase ninguém pergunta o que ela quer.<br><br>Você tentou impedir uma violência e descobriu outra: transformar a dor de alguém em assunto público.`,[
{t:'Pedir perdão a Tamar',p:304,mark:'Você entendeu tarde que a vítima não era uma peça no seu plano.'},
{t:'Procurar Natan',p:305}
],{desc:'Tamar foi exposta pelo rumor antes de ser protegida.'});
makeScene(304,'Casa do rei','Davi dividido',`Davi ouve rumor, acusação e medo misturados. Já não é prevenção. É escândalo. O rei hesita, e cada hesitação ganha testemunhas.<br><br>Você queria clareza. Entregou confusão.`,[
{t:'Pedir uma ordem real',p:305},
{t:'Recuar e deixar os responsáveis agirem',p:305}
]);
makeScene(305,'Casa de Natan','Repreensão',`Natan olha para você com tristeza.<br><br><span class="quote">Verdade sem tempo, sem testemunha e sem amor pode virar espada na mão errada.</span>Você percebe que falar certo não basta. É possível dizer algo verdadeiro e ainda ferir quem já estava ferida.`,[
{t:'Aceitar a repreensão',p:306},
{t:'Tentar justificar sua intenção',p:306,mark:'Você lutou contra a culpa se escondendo na própria intenção.'}
]);
makeScene(306,'Jerusalém','O fogo corre',`Absalão age cedo, sem espaço para arrependimento. Amnom cai. A cidade escolhe lados antes de entender a história. Davi perde filhos antes de quase perder o reino.<br><br>Você não criou o pecado deles. Mas acendeu corredores por onde ele correu mais depressa.`,[
{t:'Assumir o peso do que provocou',p:390},
{t:'Tentar reparar tarde demais',p:390}
],{desc:'A tragédia foi acelerada por uma intervenção imprudente.'});

makeScene(400,'Rota do oriente','Além do mapa familiar',`Você segue com mercadores que falam de pimenta, marfim, tecidos e portos tão distantes que Jerusalém parece virar sussurro.<br><br>Nas noites de viagem, você repete o que aprendeu: o Deus de Abraão, de Isaque e de Jacó não cabe apenas numa colina.`,[
{t:'Aprender a língua dos mercadores',p:401,mark:'Você escolheu escutar antes de ensinar.'},
{t:'Contar histórias de Israel ao redor do fogo',p:401,mark:'Você começou a falar de Deus longe de Jerusalém.'}
],{path:'Índia - A semente distante'});
makeScene(401,'Porto distante','A costa da Índia',`O mar entrega você a uma costa úmida, cheia de cheiros novos: especiarias, peixe, chuva, madeira molhada. Ninguém conhece Davi. Ninguém sabe o nome de Jerusalém.<br><br>Isso assusta você mais do que a viagem. Como falar do Deus vivo onde ninguém possui suas palavras?`,[
{t:'Começar pelo Deus criador de todas as coisas',p:402},
{t:'Começar pela história de Abraão como peregrino',p:402}
],{desc:'Rotas comerciais podiam levar histórias junto com mercadorias.'});
makeScene(402,'Casa de um mercador','Uma pergunta honesta',`Um mercador local pergunta se o seu Deus pertence apenas ao seu povo. Você quase responde rápido. Depois lembra que também é estrangeiro dependendo de hospitalidade.<br><br>Você fala de aliança, promessa e justiça. Não como dono da verdade, mas como alguém que foi alcançado por ela.`,[
{t:'Ensinar uma oração curta ao mercador',p:403,rel:'Um mercador da Índia ouviu sobre o Deus de Israel.'},
{t:'Escrever nomes hebraicos em um pedaço de cerâmica',p:403,desc:'Uma pequena memória escrita ficou em terra distante.'}
]);
makeScene(403,'Mercado de especiarias','Semente sem controle',`Alguns escutam por curiosidade. Outros por cortesia. Uma criança repete mal o nome de Jerusalém. Um idoso pergunta se justiça e misericórdia podem vir do mesmo Deus.<br><br>Você percebe que missão não é dominar o resultado. É semear sem possuir a colheita.`,[
{t:'Ficar mais tempo ensinando com cuidado',p:404},
{t:'Seguir viagem e deixar uma pequena lembrança',p:404}
]);
makeScene(404,'Costa da Índia','Rumores futuros',`Você ouve histórias de comunidades que um dia guardarão memórias judaicas nesta terra. Séculos depois, outros falarão de discípulos de Cristo chegando por rotas do mar.<br><br>Você não sabe o que é história, tradição ou providência escondida. Sabe apenas que uma pergunta sobre o Deus de Israel agora vive onde antes não vivia.`,[
{t:'Confiar a semente a Deus',p:490},
{t:'Voltar para as rotas levando o peso da distância',p:490}
],{desc:'A Índia guarda tradições antigas ligadas a judeus e cristãos do Oriente.'});

makeScene(500,'Caminho do sul','Rumo a Cuxe',`Você desce com viajantes que conhecem o Nilo, o deserto e os caminhos de Cuxe. Eles falam de reinos ao sul, ouro, oficiais de corte e gente que viaja longe para buscar sabedoria.<br><br>Jerusalém fica para trás, mas o desejo de Deus viaja com perguntas humanas.`,[
{t:'Ajudar a guardar os rolos da caravana',p:501,mark:'Você cuidou da palavra escrita como tesouro.'},
{t:'Conversar com um oficial estrangeiro',p:501,rel:'Um oficial de Cuxe percebeu sua fé.'}
],{path:'Cuxe - O servo que busca'});
makeScene(501,'Acampamento no deserto','O homem que lê',`Um oficial de Cuxe observa seus sinais escritos. Ele pergunta por que Israel canta tanto sobre justiça se seus reis também sangram a própria casa.<br><br>A pergunta atravessa você. Você fala de pecado real, juízo real e de um Deus que não abandona sua promessa por causa da ruína dos homens.`,[
{t:'Contar a história de Davi com honestidade',p:502},
{t:'Falar dos salmos que nascem de culpa e esperança',p:502}
],{desc:'A fé de Israel também confronta o pecado dos próprios reis.'});
makeScene(502,'Margem do Nilo','Fome de adoração',`O oficial não quer apenas histórias. Ele quer saber se estrangeiros podem buscar o Deus de Israel. Você lembra da tenda, da arca, dos limites, mas também lembra de promessas para as nações.<br><br>Você não consegue entregar todas as respostas. Entrega uma direção: Jerusalém.`,[
{t:'Incentivá-lo a buscar o Deus de Israel',p:503,rel:'Um homem de Cuxe decidiu buscar mais do Deus de Israel.'},
{t:'Copiar para ele um cântico sobre o Senhor',p:503,desc:'Um cântico de Israel seguiu para o sul.'}
]);
makeScene(503,'Casa de estrangeiros','Uma ponte longa',`Você imagina, sem entender como, um futuro em que outro homem de Cuxe voltará de Jerusalém lendo o profeta Isaías, e alguém lhe explicará o Cristo.<br><br>Você não antecipa o evangelho. Não inventa Escritura. Apenas ajuda uma fome antiga a encontrar caminho.`,[
{t:'Deixar que a pergunta continue depois de você',p:504},
{t:'Orar para que Deus conduza os que buscam',p:504}
],{desc:'Cuxe se torna para você um sinal de povos buscando o Deus de Israel.'});
makeScene(504,'Estrada do sul','O retorno das perguntas',`Notícias de Jerusalém chegam quebradas: Amnom morto, Absalão fugido, Davi ferido. O centro da promessa continua sangrando.<br><br>Mesmo assim, ao sul, alguém aprendeu que pode buscar o Deus de Israel sem possuir sangue de Israel.`,[
{t:'Guardar essa esperança',p:590},
{t:'Voltar com os viajantes para o norte',p:590}
]);

makeScene(600,'Caminho do leste','Rios antigos',`Você viaja para terras de rios largos, cidades antigas e escribas que medem o mundo em tábuas, impostos e presságios. Ali, poder parece menos um trono e mais uma máquina.<br><br>Você não sabe ainda, mas está olhando para a sombra de um futuro exílio.`,[
{t:'Aprender com os escribas da Mesopotâmia',p:601,mark:'Você estudou como impérios preservam e controlam memória.'},
{t:'Procurar famílias hebreias em trânsito',p:601}
],{path:'Babilônia - À sombra do exílio'});
makeScene(601,'Casa dos escribas','Memória e domínio',`Os escribas registram colheitas, guerras e reis como quem prende o tempo. Você pensa em Eli-Shama e entende que escrever pode servir à verdade ou ao domínio.<br><br>Um ancião pergunta por Jerusalém. Ele nunca viu a cidade, mas conhece o nome.`,[
{t:'Falar de Davi e da promessa',p:602},
{t:'Falar da fragilidade da casa de Davi',p:602,desc:'A promessa de Deus não apaga a culpa humana.'}
]);
makeScene(602,'Junto ao rio','A sombra do futuro',`Você percebe que esta terra poderá engolir reinos inteiros. Um dia, filhos de Judá talvez chorem junto a rios como este, lembrando Sião.<br><br>A ideia dói: Deus pode preservar seu povo até mesmo fora da terra, mas o exílio nunca será romantizado. Será ferida e disciplina.`,[
{t:'Guardar essa visão como advertência',p:603,desc:'A Babilônia futura será lugar de exílio e preservação.'},
{t:'Escrever uma advertência para quem vier depois',p:603}
]);
makeScene(603,'Mercado de tábuas','Um testemunho pequeno',`Você encontra viajantes que ridicularizam um Deus ligado a uma cidade pequena. Você quase responde com orgulho. Em vez disso, fala de um Deus que julga até o seu próprio povo.<br><br>Um jovem escriba fica incomodado. Não pela força do argumento, mas pela humildade dele.`,[
{t:'Ensinar que o Senhor não é ídolo local',p:604},
{t:'Contar que reis também respondem diante de Deus',p:604,rel:'Um jovem escriba ouviu que o Deus de Israel julga reis e impérios.'}
]);
makeScene(604,'Estrada de volta','O peso dos impérios',`Quando chegam notícias de Jerusalém, você entende que a queda começa dentro antes de chegar por fora. Amnom, Absalão e Davi pertencem ao presente. Babilônia pertence a uma sombra que ainda crescerá.<br><br>Você sai sabendo que Deus não perde seu povo nem quando seu povo perde a terra.`,[
{t:'Voltar levando a advertência',p:690},
{t:'Permanecer entre os escribas mais um tempo',p:690}
]);

makeScene(700,'Estrada do norte','Rumo a Tiro',`Você sobe com mercadores que falam de cedros, portos, bronze e contratos. Tiro não parece piedosa. Parece eficiente. Ainda assim, Deus também usa madeira, artesãos e navios no tempo certo.<br><br>Você começa a perceber que uma história santa também passa por armazéns.`,[
{t:'Trabalhar nos armazéns de madeira',p:701,mark:'Você aprendeu que coisas materiais também servem a propósitos santos.'},
{t:'Ouvir negociadores ligados à casa de Hirão',p:701}
],{path:'Tiro - Cedros e aliança'});
makeScene(701,'Tiro','Homens do mar',`O mar abre um mundo que Jerusalém não mostra. Línguas se misturam, medidas se comparam, promessas viram contratos.<br><br>Um negociante pergunta por Davi. Não como adorador, mas como homem que sabe que estabilidade muda preço, rota e confiança.`,[
{t:'Defender a honra de Jerusalém sem esconder sua crise',p:702},
{t:'Admitir que a casa de Davi está ferida',p:702,desc:'Até alianças comerciais sentem a instabilidade de Jerusalém.'}
]);
makeScene(702,'Armazém de cedros','Madeira para depois',`Cedros descem das montanhas como colunas de um futuro que você ainda não verá completo. Você pensa em Salomão, no templo, nos artesãos, no peso de preparar algo que outro construirá.<br><br>Enquanto Jerusalém sofre, aqui se movem peças de uma obra futura.`,[
{t:'Fortalecer a confiança entre mercadores de Israel e Tiro',p:703},
{t:'Impedir que explorem a crise de Jerusalém',p:703,mark:'Você tentou proteger uma aliança futura de oportunismo.'}
],{desc:'Tiro e Israel terão uma ligação importante na construção do templo.'});
makeScene(703,'Porto','Notícias de sangue',`Chegam notícias: Tamar ferida, Amnom morto, Absalão fugido. Os mercadores fazem contas. Você faz silêncio.<br><br>De longe, a dor parece virar informação. Você luta para não deixar que pessoas reais virem apenas movimento de mercado.`,[
{t:'Orar por Jerusalém',p:704},
{t:'Registrar os nomes para não esquecer',p:704}
]);
makeScene(704,'Navios e cedros','A ponte material',`Você não impediu a tragédia da casa de Davi. Mas ajudou a manter aberta uma ponte por onde madeira, técnica e confiança poderão circular.<br><br>Nem todo chamado é apagar incêndio. Às vezes é impedir que o futuro fique sem ferramentas para obedecer.`,[
{t:'Aceitar esse papel menor',p:790},
{t:'Voltar para Jerusalém com os mercadores',p:790}
]);

