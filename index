function taskText(text){
  return text.replace(/^falar de /,'').replace(/^ver /,'').replace(/^receber /,'').replace(/^sentir /,'');
}

function simpleClue(text){
  return String(text).replace(/^o /,'').replace(/^a /,'').replace(/^os /,'').replace(/^as /,'');
}

function prepA(text){
  const raw=String(text).trim();
  const lower=raw.toLowerCase();
  if(lower.startsWith('o '))return `ao ${raw.slice(2)}`;
  if(lower.startsWith('a '))return `à ${raw.slice(2)}`;
  if(lower.startsWith('os '))return `aos ${raw.slice(3)}`;
  if(lower.startsWith('as '))return `às ${raw.slice(3)}`;
  return `a ${raw}`;
}

function prepDe(text){
  const raw=String(text).trim();
  const lower=raw.toLowerCase();
  if(lower.startsWith('o '))return `do ${raw.slice(2)}`;
  if(lower.startsWith('a '))return `da ${raw.slice(2)}`;
  if(lower.startsWith('os '))return `dos ${raw.slice(3)}`;
  if(lower.startsWith('as '))return `das ${raw.slice(3)}`;
  return `de ${raw}`;
}

function cap(text){
  const raw=String(text);
  return raw.charAt(0).toUpperCase()+raw.slice(1);
}

function verbEstar(text){
  const first=String(text).trim().toLowerCase().split(/\s+/)[0];
  if(String(text).toLowerCase().includes(' e '))return 'estão';
  return ['os','as','mercadores','marinheiros','viajantes','mensageiros','guardas','mulheres','crianças','peregrinos','trabalhadores','homens','capitães','negociadores','escribas','servos','pastores'].includes(first)?'estão':'está';
}

function sceneNudge(pathName,place){
  if((place==='Pátio de Tamar'||place==='Casa de Absalão')&&pathName.includes('O aviso'))return ', procurando proteger sem expor';
  if((place==='Pátio de Tamar'||place==='Casa de Absalão')&&pathName.includes('Zelo sem sabedoria'))return ', antes que o rumor cresça';
  return '';
}

function pathFrame(pathName){
  if(pathName.includes('O aviso'))return 'sem espalhar o aviso';
  if(pathName.includes('A testemunha'))return 'como testemunha cuidadosa';
  if(pathName.includes('Zelo sem sabedoria'))return 'sem alimentar escândalo';
  if(pathName.includes('Índia'))return 'na rota dos mercadores';
  if(pathName.includes('Cuxe'))return 'entre viajantes do sul';
  if(pathName.includes('Babilônia'))return 'longe de Jerusalém';
  if(pathName.includes('Tiro'))return 'entre porto e aliança';
  return 'sem perder o fio da história';
}

