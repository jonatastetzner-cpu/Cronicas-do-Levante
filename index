  const sets=[
    [
      [`Guardar essa ordem dos fatos e avançar para ${place}`,`Olhar de novo para quem ficou do lado de fora`, `Esperar ${person} nomear o problema sem pressa`, `Sair dali antes que confundam silêncio com culpa`],
      [`Reparar no rosto que mudou quando ${clue} apareceram`,`Voltar ao canto onde a fala começou baixa`,`Deixar ${person} concluir a tarefa antes da próxima pergunta`,`Seguir com o cuidado aprendido em ${route}`],
      [`Separar o que viu do que apenas supôs`,`Observar a entrada usada pelos mais pobres`,`Pedir a ${person} que repita o nome mais importante`,`Continuar sem transformar a pista em anúncio`]
    ],
    [
      [`Terminar o serviço antes de pedir explicação`, `Aceitar outra tarefa curta ao lado de ${person}`, `Perguntar enquanto carrega o peso mais leve`, `Seguir depois de devolver a ajuda recebida`],
      [`Ficar até a última corda ser recolhida`,`Pedir a ferramenta que todos evitam pegar`,`Deixar ${person} perceber que você não está usando a ajuda como moeda`,`Caminhar adiante com as mãos ainda sujas do trabalho`],
      [`Levar água para quem não entrou na conversa`,`Consertar o erro pequeno que ninguém quis assumir`,`Perguntar a ${person} pelo costume de ${place}`,`Sair só depois de saber quem ficou desamparado`]
    ],
    [
      [`Confirmar a informação com alguém que viu de perto`,`Guardar o assunto até encontrar um lugar sem curiosos`, `Afastar quem pode ser exposto por ${clue}`,`Ir adiante sem dar nome ao boato`],
      [`Pedir uma segunda versão antes de agir`,`Proteger a pessoa citada antes de procurar culpados`,`Levar a pista a ${person} longe da multidão`,`Deixar ${task} amadurecer como pergunta, não como acusação`],
      [`Rever a ordem dos acontecimentos com calma`,`Chamar só quem tem responsabilidade sobre ${place}`,`Cobrir a vergonha de quem já foi ferido`,`Não permitir que ${lesson} vire frase de efeito`]
    ],
    [
      [`Manter a pergunta mesmo quando os olhares pesarem`,`Aceitar que agora você ficou visível em ${place}`,`Procurar alguém que conheça a casa por dentro`,`Sair antes que a conversa vire disputa`],
      [`Falar com ${person} sem levantar a voz`,`Pedir que escutem a pessoa mais fraca primeiro`,`Recuar quando perceber que sua pressa atrapalha`,`Seguir com a pergunta ainda aberta`],
      [`Assumir o risco de ser mal interpretado`,`Chamar pelo nome quem pode responder de verdade`,`Pedir que parem de repetir ${clue} como acusação`,`Deixar a sala antes que sua presença vire o assunto`]
    ]
  ];
  const stats=['escuta','servico','prudencia','ousadia'];
  return sets[ai][ci%3].map((t,idx)=>({t:continueAction(t,ch,sourceTitle,idx,pathName),p:next,stat:stats[ai],mark:ai===3?'Você aceitou ficar mais visível na história.':null}));
}

function continueAction(t,ch,sourceTitle,idx,pathName){
  const place=ch[0], person=ch[1], clue=ch[2], task=ch[3], lesson=ch[4];
  const frame=pathFrame(pathName);
  const part=phaseLabel(sourceTitle);
  const tail=[
    ` em ${place}, após ${part}; ${frame}`,
    ` com ${person}, após ${part}; ${frame}`,
    ` sobre ${clue}, após ${part}; ${frame}`,
    ` antes de ${task}, após ${part}; ${frame}`
  ][idx];
  return `${t}${tail}`;
}

function phaseLabel(title){
  const clean=title.toLowerCase();
  if(clean.includes(' - uma ajuda'))return 'ajudar';
  if(clean.includes(' - uma pista'))return 'a pista';
  if(clean.includes(' - comida'))return 'a refeição';
  if(clean.includes(' - a pergunta'))return 'a pergunta';
  if(clean.includes(' - problema'))return 'a confusão';
  if(clean.includes(' - notícia'))return 'a notícia';
  if(clean.includes(' - noite'))return 'a noite';
  if(clean.includes(' - manhã'))return 'a manhã';
  return 'a chegada';
}

const OPENING_REWRITE={
  0:{body:`Pedras quentes. Sol forte. Você desperta num beco estreito, entre muros claros. Há poeira na boca, cheiro de pão no ar e vozes numa língua que parece antiga demais para ainda estar viva.<br><br>Você procura o celular. A tela está morta. Nada vibra. Nada responde. Antes de entender onde está, você precisa decidir como aparecer diante de um mundo que ainda não sabe seu nome.`,acao:[
